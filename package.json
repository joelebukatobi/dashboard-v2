{
  "name": "blogcms-admin",
  "version": "1.0.0",
  "description": "BlogCMS Admin Dashboard - Fastify backend with HTMX",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build:css": "sass scss/main.scss public/css/main.css --style=compressed && postcss public/css/main.css -o public/css/main.css",
    "build:js": "esbuild src/client/main.js --bundle --minify --outfile=public/js/main.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "node scripts/seed.js",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^8.0.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.1.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.28.1",
    "fastify-html": "^0.3.2",
    "nodemailer": "^6.9.14",
    "pg": "^8.11.3",
    "pino": "^9.3.1",
    "pino-pretty": "^11.2.2",
    "preline": "^4.0.1",
    "sharp": "^0.33.4",
    "slugify": "^1.6.6",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.3",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.21.0",
    "esbuild": "^0.20.0",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.40",
    "postcss-cli": "^11.0.0",
    "sass": "^1.77.8",
    "tailwindcss": "^3.4.7",
    "vitest": "^2.0.3"
  },
  "keywords": [
    "blog",
    "cms",
    "fastify",
    "htmx",
    "drizzle",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
